POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me_with_a_strong_password
POSTGRES_DB=coldharbourdb

COLDHARBOUR_BOOTSTRAP_EMAIL=admin@example.com
COLDHARBOUR_BOOTSTRAP_PASSWORD=change_me

COLDHARBOUR_JWT_SIGNING_KEY=change_me_with_at_least_32_random_chars

COLDHARBOUR_PUBLIC_ORIGIN=https://music.yourdomain.com

# Soft cap (bytes) for a single assembled WebSocket message on /ws/playback. Default 1 MB.
COLDHARBOUR_WS_MAX_FRAME_BYTES=1048576

# Maximum number of tracks accepted in a single setQueue over /ws/playback. Default 1000.
COLDHARBOUR_WS_MAX_QUEUE_SIZE=1000

CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
